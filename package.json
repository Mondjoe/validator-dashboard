  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.0.4",
    "ts-node": "^10.9.1",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0"
  }
